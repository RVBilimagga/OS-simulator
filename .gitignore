cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.env
.venv
venv/
env/
pip-log.txt
pip-delete-this-directory.txt

# Node / Frontend
node_modules/
dist/
.DS_Store
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# C compiled binaries
c_code/bin/
*.o
*.out
*.exe
*.a
*.so

# VS Code
.vscode/

# OS
.DS_Store
Thumbs.db
EOF